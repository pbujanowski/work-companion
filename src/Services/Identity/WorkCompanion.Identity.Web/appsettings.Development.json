{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "Origins": [
      "http://localhost:3000"
    ]
  },
  "ConnectionStrings": {
    "Application": "Data Source=WorkCompanion.Identity.Web.sqlite;Cache=Shared"
  },
  "DatabaseProvider": "Sqlite",
  "ValidIssuers": [
    "http://localhost:4000/"
  ],
  "OpenIddict": {
    "MobileApp": {
      "ClientId": "work-companion-mobile",
      "DisplayName": "Work Companion mobile application",
      "RedirectUri": "http://localhost:3000/authentication/login-callback",
      "PostLogoutRedirectUri": "http://localhost:3000/authentication/logout-callback"
    }
  }
}
